{
  "manifest_version": 3,
  "name": "CreatorGraph",
  "version": "1.1.0",
  "description": "Discover your Twitter tribes and who actually matters in your network. Client-side graph intelligence — no servers, no tracking.",
  "author": "Shango Bashi",
  "permissions": ["scripting", "activeTab", "storage", "tabs"],
  "host_permissions": ["https://twitter.com/*", "https://x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["results/results.html", "results/results.css", "results/results.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
